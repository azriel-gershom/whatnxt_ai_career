# ═══════════════════════════════════════════════════════════════
#  WhatNxt — Git Ignore
# ═══════════════════════════════════════════════════════════════

# Python
__pycache__/
*.py[cod]
*.pyc
*.pyo
*.pyd
*.egg-info/
venv/
.venv/
env/
.Python

# Environment variables
.env
.env.local

# Databases (local dev — regenerated on startup)
db/*.db
*.db

# Large Kaggle datasets (too big for Git)
data/job_data.csv

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo

# Logs & Temp
*.log
logs/
*.tmp
*.temp
