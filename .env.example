#  WhatNxt — Example Environment Variables
#  Copy this to .env and fill in your keys
# ═══════════════════════════════════════════════════════════════

# 🔑 Gemini AI Keys (comma-separated, get free at https://aistudio.google.com/apikey)
GEMINI_KEYS=your-gemini-key-1,your-gemini-key-2

# 📺 YouTube Data API Key (optional, for live video search)
YOUTUBE_API_KEY=your-youtube-api-key
